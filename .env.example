# Backend (backend/) — copy to your environment / Replit secrets / App Runner runtime.

# --- Core (required) ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/seo_admin
PORT=5000
NODE_ENV=development
# JWT signing secret — generate a long random value (e.g. `openssl rand -hex 32`).
SESSION_SECRET=change-me

# --- CORS ---
# Comma-separated allowlist of origins permitted to call the API.
# In production set this to the CloudFront / app domain. Defaults to http://localhost:3000.
CORS_ORIGINS=http://localhost:3000

# --- Real rank measurement (geo-grid heatmap + keyword refresh) ---
# Serper.dev SERP API key. Without it, /geo-grids/:id/generate and
# /keywords/:id/refresh return 503 (no random/demo ranks are produced).
SERP_API_KEY=
SERP_PROVIDER=serper

# --- Keyword idea generation (optional) ---
# Google autocomplete suggestions are free (no key). A DeepSeek key adds intent +
# commercial-intent labels and "AI search" questions; without it, ideas still work
# with neutral labels.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# --- Frontend (frontend/) dev server ---
# PORT=3000
# BASE_PATH=/
# API_PORT=5000
# NODE_ENV=development
